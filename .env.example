# Copy this file to `.env` and configure ONE summary provider (all optional).
# With none set, the app still works — it shows each feed's own snippet.

# ── FREE options ───────────────────────────────────────────────────────────

# 1) Google Gemini — free tier, no credit card. Easiest free AI.
#    Get a key (2 min): https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# 2) Groq — free tier, very fast. https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# 3) Ollama — 100% free + local + private. Install https://ollama.com then:
#    `ollama pull llama3.2`
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# ── PAID option ────────────────────────────────────────────────────────────

# 4) Anthropic Claude — pennies per 1,000 summaries. console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# BRIEF_MODEL=claude-haiku-4-5

# Force a specific provider (otherwise auto-detected from the keys above):
# SUMMARY_PROVIDER=gemini   # gemini | groq | ollama | anthropic | none

# ── Optional: better inline reading of HARD paywalls (NYT/WSJ/WaPo) ─────────
# Jina Reader renders pages server-side. Anonymous access is blocked for these
# domains, but a FREE key is allowed. Get one: https://jina.ai/reader (free tier)
# JINA_API_KEY=jina_...

PORT=3001
